{
  "sources": [
    {
      "name": "clarivate_mjl_export",
      "type": "clarivate_mjl_csv",
      "path": "import/clarivate_master_journal_list.csv",
      "delimiter": ",",
      "field_mapping": {
        "title": "Journal name",
        "website": "Journal website",
        "publisher": "Publisher",
        "discipline": "Web of Science Categories",
        "language": "Languages",
        "jcr_quartile": "Journal Impact Factor Quartile",
        "impact_factor": "Journal Impact Factor",
        "aims_and_scope": "Aims & Scope"
      },
      "static_fields": {
        "indexing": ["SSCI", "AHCI", "ESCI"],
        "source_tags": ["clarivate_master_journal_list"]
      }
    },
    {
      "name": "ssci_all_export",
      "type": "csv",
      "path": "import/ssci_all_export.csv",
      "delimiter": ",",
      "field_mapping": {
        "title": "journal_title",
        "website": "website",
        "publisher": "publisher",
        "discipline": "discipline",
        "language": "language",
        "jcr_quartile": "jcr_quartile",
        "impact_factor": "impact_factor",
        "review_cycle_months": "review_cycle_months",
        "acceptance_rate": "acceptance_rate",
        "aims_and_scope": "aims_and_scope"
      },
      "static_fields": {
        "indexing": ["SSCI"],
        "source_tags": ["ssci_export_all"]
      }
    },
    {
      "name": "jcr_law_export",
      "type": "csv",
      "path": "import/jcr_law_export.csv",
      "delimiter": ",",
      "field_mapping": {
        "title": "journal_title",
        "website": "website",
        "publisher": "publisher",
        "jcr_quartile": "jcr_quartile",
        "impact_factor": "impact_factor",
        "review_cycle_months": "review_cycle_months",
        "acceptance_rate": "acceptance_rate",
        "aims_and_scope": "aims_and_scope"
      },
      "static_fields": {
        "discipline": "law",
        "language": "en",
        "indexing": ["JCR"],
        "source_tags": ["jcr_export"]
      }
    },
    {
      "name": "cssci_law_page",
      "type": "html_list",
      "url": "https://cssrac.nju.edu.cn/",
      "item_selector": "table tbody tr",
      "field_mapping": {
        "title": "td:nth-child(1)",
        "publisher": "td:nth-child(2)"
      },
      "static_fields": {
        "discipline": "law",
        "language": "zh",
        "indexing": ["CSSCI"],
        "source_tags": ["cssci_html"]
      },
      "notes": "Adjust selectors to the real law-journal page structure before production use."
    },
    {
      "name": "pku_core_law_manual",
